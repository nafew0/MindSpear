# ============================================
# MindSpear Frontend — PRODUCTION
# Copy to /var/www/mindspear/frontend/.env.production.local on the server,
# then run: npm ci && npm run build
# ============================================

# Backend API (same-domain Nginx path -> Laravel/PHP-FPM)
NEXT_PUBLIC_API_BASE_URL=https://mindspear.app/api/v1

# Reverb WebSocket — must match backend REVERB_APP_KEY exactly
NEXT_PUBLIC_REVERB_APP_KEY=REPLACE_WITH_REAL_APP_KEY
NEXT_PUBLIC_REVERB_HOST=mindspear.app
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https

# Public frontend URL
NEXT_PUBLIC_APP_URL=https://mindspear.app

# Server-side only — never prefix with NEXT_PUBLIC_ or it leaks to the browser
OPENAI_API_KEY=REPLACE_WITH_REAL_OPENAI_KEY
